# NovaPool — Environment

# Unichain Mainnet
RPC_URL=https://mainnet.unichain.org
CHAIN_ID=130

# Unichain Sepolia (uncomment to deploy to testnet instead)
# RPC_URL=https://sepolia.unichain.org
# CHAIN_ID=1301

# Deployer wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
DEPLOYER_ADDRESS=0xYOUR_WALLET_ADDRESS

# Uniswap v4 PoolManager on Unichain Mainnet
POOL_MANAGER_ADDRESS=0x1f98400000000000000000000000000000000004

# Filled after deployment
HOOK_ADDRESS=

# Block explorer verification
ETHERSCAN_API_KEY=
